{
  "rules": {
    "collabSessions": {
      "$boardId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "boards": {
      "$boardId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
