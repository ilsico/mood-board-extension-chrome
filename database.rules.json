{
  "rules": {
    "collabSessions": {
      "$boardId": {
        ".read": "auth != null",
        ".write": "auth != null && (newData.exists() || !data.child('meta/ownerId').exists() || data.child('meta/ownerId').val() === 'u_' + auth.uid)",
        "meta": {
          "ownerId": { ".validate": "newData.isString() && newData.val().length <= 128" }
        }
      }
    },

    "boards": {
      "$boardId": {
        ".read": "auth != null",
        ".write": "auth != null",

        "name": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "savedAt": { ".validate": "newData.isNumber()" },
        "snapshotUrl": { ".validate": "newData.isString() && newData.val().length <= 4096" },

        "activity": {
          "$entryId": {
            "uid": { ".validate": "newData.val() === auth.uid" },
            "at": { ".validate": "newData.isNumber()" },
            "action": { ".validate": "newData.isString() && newData.val().length <= 64" }
          }
        }
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
