{
  "manifest_version": 3,
  "name": "Moodboard",
  "version": "1.0",
  "description": "Clic droit sur n'importe quelle image pour l'ajouter directement à un board Moodboard.",

  "permissions": [
    "contextMenus",
    "storage",
    "unlimitedStorage",
    "activeTab",
    "tabs"
  ],

  "host_permissions": ["<all_urls>"],

  "icons": {
    "16": "icon extension/icon16.png",
    "48": "icon extension/icon48.png",
    "128": "icon extension/icon128.png"
  },

  "action": {
    "default_title": "Ouvrir mon Moodboard",
    "default_icon": "icon extension/icon48.png"
  },

  "background": {
    "service_worker": "background.js"
  }
}