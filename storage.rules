rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Images des sessions collaboratives (collab.js _uploadImageToStorage).
    // SANS cette regle, le chemin n'est couvert par aucune match : Firebase Storage
    // refuse par defaut, l'upload echoue silencieusement et collab.js retombe sur
    // du base64 en base pour les petites images — les grandes sont perdues.
    match /collabImages/{boardId}/{elementId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && (request.resource.contentType == null
                       || request.resource.contentType.matches('image/.*'));
    }

    match /boards/{boardId}/{filename} {
      // Lecture ouverte : les images sont affichees via <img src="...">, une requete
      // qui ne porte aucun jeton d'authentification. Restreindre ici casserait
      // l'affichage des snapshots dans la PWA et les liens de partage.
      allow read: if true;

      // Ecriture : utilisateur authentifie, images uniquement, 20 Mo max.
      // Sans plafond, n'importe quel compte peut remplir le bucket a vos frais.
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && (request.resource.contentType == null
                       || request.resource.contentType.matches('image/.*'));
    }
  }
}
